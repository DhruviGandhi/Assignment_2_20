<%- include("../partial/header") %>
<%- include("../partial/navbar") %>

<div class="container mt-4">
  <h2><%= category.name %></h2>

  <!-- Subcategories -->
  <% if (subCategories && subCategories.length > 0) { %>
    <h4 class="mt-3">Subcategories</h4>
    <div class="row">
      <% subCategories.forEach(sub => { %>
        <div class="col-md-3 mb-3">
          <div class="card text-center p-3 shadow-sm">
            <h5><%= sub.name %></h5>
            <a href="/category/<%= sub._id %>" class="btn btn-primary btn-sm mt-2">View</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Products -->
  <h4 class="mt-4">Products</h4>
  <div class="row">
    <% if (products.length === 0) { %>
      <p>No products found in this category.</p>
    <% } else { %>
      <% products.forEach(prod => { %>
        <div class="col-md-3 mb-3">
          <div class="card p-2 shadow-sm h-100">
            <img src="<%= prod.image %>" class="card-img-top" style="height:150px; object-fit:cover;" alt="<%= prod.name %>">
            <div class="card-body">
              <h5 class="card-title"><%= prod.name %></h5>
              <p class="card-text">$<%= prod.price %></p>
              <a href="/product/<%= prod._id %>" class="btn btn-primary btn-sm">View</a>
              <a href="/cart/add/<%= prod._id %>" class="btn btn-success btn-sm">Add to Cart</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<%- include("../partial/footer") %>
