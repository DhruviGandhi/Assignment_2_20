<%- include("../partial/header") %>
<%- include("../partial/navbar") %>

<div class="container mt-4">
  <h2>Welcome to Our Shop</h2>

  <!-- Categories Section -->
  <h3 class="mt-4">Shop by Category</h3>
  <div class="row">
    <% categories.forEach(cat => { %>
      <div class="col-md-3 mb-3">
        <div class="card text-center p-3 shadow-sm">
          <h5><%= cat.name %></h5>
          <a href="/category/<%= cat._id %>" class="btn btn-primary btn-sm mt-2">View</a>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Latest Products -->
  <h3 class="mt-4">Latest Products</h3>
  <div class="row">
    <% latestProducts.forEach(prod => { %>
      <div class="col-md-3 mb-3">
        <div class="card p-2 shadow-sm h-100">
          <img src="<%= prod.image %>" class="card-img-top" style="height:150px; object-fit:cover;" alt="<%= prod.name %>">
          <div class="card-body">
            <h5 class="card-title"><%= prod.name %></h5>
            <p class="card-text">$<%= prod.price %></p>
            <a href="/product/<%= prod._id %>" class="btn btn-primary btn-sm">View</a>
            <a href="/cart/add/<%= prod._id %>" class="btn btn-success btn-sm">Add to Cart</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<%- include("../partial/footer") %>
